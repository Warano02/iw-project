<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Classroom-of-Elite — Inscription & Assignment</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --rose:      #F2638A;
      --rose-pale: #FFD6E3;
      --rose-dark: #C43F6A;
      --noir:      #141010;
      --gris:      #3A3232;
      --blanc:     #FAFAF8;
      --trait:     #E8D8DC;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--blanc);
      color: var(--noir);
      min-height: 100vh;
    }

    /* ─── NAV ─── */
    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 22px 48px;
      border-bottom: 1.5px solid var(--trait);
      position: sticky;
      top: 0;
      background: var(--blanc);
      z-index: 100;
    }
    .logo {
      font-family: 'DM Serif Display', serif;
      font-size: 1.55rem;
      letter-spacing: -0.5px;
      color: var(--noir);
    }
    .logo span { color: var(--rose); }
    nav ul {
      list-style: none;
      display: flex;
      gap: 36px;
    }
    nav ul a {
      text-decoration: none;
      font-size: .85rem;
      font-weight: 500;
      letter-spacing: .5px;
      color: var(--gris);
      text-transform: uppercase;
      transition: color .2s;
    }
    nav ul a:hover { color: var(--rose); }
    .nav-cta {
      background: var(--noir);
      color: var(--blanc) !important;
      padding: 9px 22px;
      border-radius: 100px;
      transition: background .2s !important;
    }
    .nav-cta:hover { background: var(--rose) !important; color: var(--blanc) !important; }

    /* ─── TABS ─── */
    .tabs {
      display: flex;
      justify-content: center;
      gap: 0;
      margin: 52px 0 0;
    }
    .tab-btn {
      font-family: 'DM Serif Display', serif;
      font-size: 1.1rem;
      padding: 14px 42px;
      border: 1.5px solid var(--trait);
      background: transparent;
      cursor: pointer;
      letter-spacing: -.3px;
      color: #aaa;
      transition: all .25s;
    }
    .tab-btn:first-child { border-radius: 8px 0 0 8px; }
    .tab-btn:last-child  { border-radius: 0 8px 8px 0; border-left: none; }
    .tab-btn.active {
      background: var(--noir);
      color: var(--blanc);
      border-color: var(--noir);
    }

    /* ─── PAGES ─── */
    .page { display: none; animation: fadeUp .35s ease both; }
    .page.active { display: block; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ─── REGISTRATION ─── */
    .reg-wrapper {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: calc(100vh - 180px);
    }

    .reg-panel {
      background: var(--noir);
      padding: 72px 60px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }
    .reg-panel::before {
      content: '';
      position: absolute;
      width: 420px; height: 420px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(242,99,138,.35) 0%, transparent 70%);
      top: -80px; right: -80px;
    }
    .reg-panel::after {
      content: '';
      position: absolute;
      width: 260px; height: 260px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(242,99,138,.2) 0%, transparent 70%);
      bottom: 40px; left: -60px;
    }
    .panel-eyebrow {
      font-size: .72rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--rose);
      font-weight: 600;
      margin-bottom: 18px;
    }
    .panel-title {
      font-family: 'DM Serif Display', serif;
      font-size: 3rem;
      line-height: 1.15;
      color: var(--blanc);
      margin-bottom: 22px;
    }
    .panel-title em { color: var(--rose); font-style: italic; }
    .panel-desc {
      font-size: .95rem;
      color: rgba(250,250,248,.55);
      line-height: 1.75;
      max-width: 320px;
      margin-bottom: 44px;
    }
    .feature-list { list-style: none; display: flex; flex-direction: column; gap: 14px; }
    .feature-list li {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: .88rem;
      color: rgba(250,250,248,.75);
    }
    .feat-dot {
      width: 28px; height: 28px;
      background: var(--rose);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      font-size: .75rem;
    }

    .reg-form-side {
      padding: 72px 64px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .form-header { margin-bottom: 38px; }
    .form-header h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.9rem;
      margin-bottom: 8px;
      color: var(--noir);
    }
    .form-header p { font-size: .88rem; color: #888; }
    .form-header p a { color: var(--rose); text-decoration: none; font-weight: 500; }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
    .field { margin-bottom: 20px; }
    .field label {
      display: block;
      font-size: .78rem;
      font-weight: 600;
      letter-spacing: .6px;
      text-transform: uppercase;
      color: var(--gris);
      margin-bottom: 8px;
    }
    .field input,
    .field select {
      width: 100%;
      padding: 13px 16px;
      border: 1.5px solid var(--trait);
      border-radius: 8px;
      font-family: 'DM Sans', sans-serif;
      font-size: .92rem;
      color: var(--noir);
      background: var(--blanc);
      outline: none;
      transition: border-color .2s, box-shadow .2s;
    }
    .field input:focus,
    .field select:focus {
      border-color: var(--rose);
      box-shadow: 0 0 0 4px rgba(242,99,138,.12);
    }
    .field input::placeholder { color: #bbb; }

    .password-wrap { position: relative; }
    .password-wrap input { padding-right: 44px; }
    .toggle-pw {
      position: absolute;
      right: 14px; top: 50%;
      transform: translateY(-50%);
      background: none; border: none;
      cursor: pointer; color: #bbb; font-size: .8rem;
      font-weight: 600; letter-spacing: .5px;
    }

    .strength-bar {
      height: 4px;
      border-radius: 2px;
      background: var(--trait);
      margin-top: 8px;
      overflow: hidden;
    }
    .strength-fill {
      height: 100%;
      border-radius: 2px;
      width: 0%;
      transition: width .3s, background .3s;
    }

    .checkbox-row {
      display: flex; align-items: flex-start;
      gap: 10px; margin: 10px 0 24px;
    }
    .checkbox-row input[type="checkbox"] {
      width: 17px; height: 17px; margin-top: 2px;
      accent-color: var(--rose); cursor: pointer; flex-shrink: 0;
    }
    .checkbox-row span { font-size: .83rem; color: #777; line-height: 1.5; }
    .checkbox-row a { color: var(--rose); text-decoration: none; }

    .btn-submit {
      width: 100%;
      padding: 15px;
      background: var(--rose);
      color: var(--blanc);
      border: none;
      border-radius: 8px;
      font-family: 'DM Sans', sans-serif;
      font-size: .95rem;
      font-weight: 600;
      cursor: pointer;
      letter-spacing: .3px;
      transition: background .2s, transform .15s;
      position: relative;
      overflow: hidden;
    }
    .btn-submit:hover { background: var(--rose-dark); transform: translateY(-1px); }
    .btn-submit:active { transform: translateY(0); }

    .divider {
      display: flex; align-items: center;
      gap: 14px; margin: 22px 0;
      color: #bbb; font-size: .8rem;
    }
    .divider::before, .divider::after {
      content: ''; flex: 1; height: 1px; background: var(--trait);
    }

    .social-btns { display: flex; gap: 12px; }
    .social-btn {
      flex: 1; padding: 11px;
      border: 1.5px solid var(--trait);
      border-radius: 8px;
      background: none; cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      font-size: .83rem; font-weight: 500;
      color: var(--gris);
      display: flex; align-items: center;
      justify-content: center; gap: 8px;
      transition: border-color .2s, background .2s;
    }
    .social-btn:hover { border-color: var(--rose); background: var(--rose-pale); }

    /* ─── ASSIGNMENT ─── */
    .assign-wrapper {
      max-width: 900px;
      margin: 0 auto;
      padding: 56px 32px 80px;
    }

    .assign-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 44px;
      padding-bottom: 28px;
      border-bottom: 1.5px solid var(--trait);
    }
    .assign-meta { max-width: 580px; }
    .course-pill {
      display: inline-block;
      background: var(--rose-pale);
      color: var(--rose-dark);
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      padding: 5px 14px;
      border-radius: 100px;
      margin-bottom: 14px;
    }
    .assign-title {
      font-family: 'DM Serif Display', serif;
      font-size: 2.1rem;
      line-height: 1.2;
      margin-bottom: 12px;
    }
    .assign-desc { font-size: .9rem; color: #777; line-height: 1.7; }

    .assign-stats {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 10px;
      flex-shrink: 0;
    }
    .deadline-badge {
      background: var(--noir);
      color: var(--blanc);
      border-radius: 8px;
      padding: 10px 18px;
      text-align: center;
    }
    .deadline-badge .dl-label { font-size: .68rem; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,.5); }
    .deadline-badge .dl-date  { font-family: 'DM Serif Display', serif; font-size: 1.1rem; color: var(--blanc); }

    .progress-ring-wrap { display: flex; align-items: center; gap: 10px; }
    .progress-label { font-size: .8rem; color: #888; }

    /* Steps */
    .steps-row {
      display: flex;
      gap: 0;
      margin-bottom: 40px;
      border: 1.5px solid var(--trait);
      border-radius: 10px;
      overflow: hidden;
    }
    .step-item {
      flex: 1; padding: 16px 20px;
      border-right: 1.5px solid var(--trait);
      display: flex; align-items: center; gap: 12px;
      cursor: pointer;
      transition: background .2s;
    }
    .step-item:last-child { border-right: none; }
    .step-item:hover { background: #fdf0f4; }
    .step-item.done { background: #fdf0f4; }
    .step-num {
      width: 28px; height: 28px; border-radius: 50%;
      background: var(--trait); display: flex;
      align-items: center; justify-content: center;
      font-size: .75rem; font-weight: 700; color: #999;
      flex-shrink: 0; transition: all .2s;
    }
    .step-item.done .step-num { background: var(--rose); color: #fff; }
    .step-item.current .step-num { background: var(--noir); color: #fff; }
    .step-text { font-size: .83rem; }
    .step-text strong { display: block; font-weight: 600; color: var(--noir); font-size: .85rem; }
    .step-text span { color: #aaa; font-size: .75rem; }

    /* Upload zone */
    .section-title {
      font-family: 'DM Serif Display', serif;
      font-size: 1.25rem;
      margin-bottom: 18px;
    }

    .upload-zone {
      border: 2px dashed var(--trait);
      border-radius: 12px;
      padding: 56px 32px;
      text-align: center;
      cursor: pointer;
      transition: border-color .2s, background .2s;
      margin-bottom: 32px;
      position: relative;
    }
    .upload-zone:hover {
      border-color: var(--rose);
      background: rgba(242,99,138,.03);
    }
    .upload-zone.dragover {
      border-color: var(--rose);
      background: var(--rose-pale);
    }
    .upload-icon {
      width: 56px; height: 56px;
      background: var(--rose-pale);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 18px;
      font-size: 1.4rem;
    }
    .upload-zone h3 { font-size: 1rem; font-weight: 600; margin-bottom: 6px; }
    .upload-zone p  { font-size: .83rem; color: #999; margin-bottom: 18px; }
    .btn-browse {
      display: inline-block;
      padding: 9px 24px;
      border: 1.5px solid var(--noir);
      border-radius: 100px;
      font-size: .82rem;
      font-weight: 600;
      cursor: pointer;
      background: none;
      font-family: 'DM Sans', sans-serif;
      transition: all .2s;
    }
    .btn-browse:hover { background: var(--noir); color: var(--blanc); }

    .file-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 28px; }
    .file-item {
      display: flex; align-items: center;
      padding: 14px 18px;
      border: 1.5px solid var(--trait);
      border-radius: 8px;
      gap: 14px;
      animation: fadeUp .25s ease both;
    }
    .file-icon {
      width: 36px; height: 36px;
      background: var(--rose-pale);
      border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      font-size: .75rem; font-weight: 700; color: var(--rose-dark);
      flex-shrink: 0;
    }
    .file-info { flex: 1; }
    .file-info strong { display: block; font-size: .88rem; font-weight: 600; }
    .file-info span { font-size: .75rem; color: #999; }
    .file-remove {
      background: none; border: none; cursor: pointer;
      color: #ccc; font-size: 1.1rem; line-height: 1;
      transition: color .2s;
    }
    .file-remove:hover { color: var(--rose); }

    /* Textarea */
    .field textarea {
      width: 100%;
      padding: 14px 16px;
      border: 1.5px solid var(--trait);
      border-radius: 8px;
      font-family: 'DM Sans', sans-serif;
      font-size: .92rem;
      color: var(--noir);
      background: var(--blanc);
      outline: none;
      resize: vertical;
      min-height: 120px;
      transition: border-color .2s, box-shadow .2s;
    }
    .field textarea:focus {
      border-color: var(--rose);
      box-shadow: 0 0 0 4px rgba(242,99,138,.12);
    }

    /* Bottom bar */
    .assign-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 28px;
      border-top: 1.5px solid var(--trait);
      margin-top: 36px;
    }
    .btn-secondary {
      padding: 13px 28px;
      border: 1.5px solid var(--trait);
      border-radius: 8px;
      background: none;
      font-family: 'DM Sans', sans-serif;
      font-size: .9rem;
      font-weight: 500;
      cursor: pointer;
      color: var(--gris);
      transition: all .2s;
    }
    .btn-secondary:hover { border-color: var(--noir); color: var(--noir); }

    .btn-primary {
      padding: 13px 32px;
      background: var(--noir);
      color: var(--blanc);
      border: none;
      border-radius: 8px;
      font-family: 'DM Sans', sans-serif;
      font-size: .9rem;
      font-weight: 600;
      cursor: pointer;
      transition: background .2s, transform .15s;
      display: flex; align-items: center; gap: 8px;
    }
    .btn-primary:hover { background: var(--rose); transform: translateY(-1px); }

    /* Toast */
    .toast {
      position: fixed;
      bottom: 32px; right: 32px;
      background: var(--noir);
      color: var(--blanc);
      padding: 14px 22px;
      border-radius: 10px;
      font-size: .88rem;
      font-weight: 500;
      display: flex; align-items: center; gap: 10px;
      transform: translateY(80px);
      opacity: 0;
      transition: all .35s cubic-bezier(.34,1.56,.64,1);
      z-index: 999;
      box-shadow: 0 8px 30px rgba(0,0,0,.15);
    }
    .toast.show { transform: translateY(0); opacity: 1; }
    .toast-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--rose); }

    /* Responsive */
    @media (max-width: 860px) {
      .reg-wrapper { grid-template-columns: 1fr; }
      .reg-panel { padding: 48px 36px; }
      .reg-form-side { padding: 48px 32px; }
      .form-row { grid-template-columns: 1fr; }
      .assign-header { flex-direction: column; gap: 24px; }
      .assign-stats { align-items: flex-start; }
      .steps-row { flex-direction: column; }
      .step-item { border-right: none; border-bottom: 1.5px solid var(--trait); }
      .step-item:last-child { border-bottom: none; }
      nav { padding: 16px 24px; }
      nav ul { display: none; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="logo"><span>Classroom-of-Elite</span></div>
  <ul>
    <li><a href="#">Cours</a></li>
    <li><a href="#">Parcours</a></li>
    <li><a href="#">Instructeurs</a></li>
    <li><a href="#" class="nav-cta">Commencer</a></li>
  </ul>
</nav>

<!-- TABS -->
<div class="tabs">
  <button class="tab-btn active" onclick="switchTab('register')">Inscription</button>
  <button class="tab-btn" onclick="switchTab('assignment')">Assignment</button>
</div>

<!-- ═══════ PAGE INSCRIPTION ═══════ -->
<div id="page-register" class="page active">
  <div class="reg-wrapper">

    <div class="reg-panel">
      <div class="panel-eyebrow">Bienvenue</div>
      <h1 class="panel-title">
        Apprenez à<br><em>votre rythme,</em><br>à votre façon.
      </h1>
      <p class="panel-desc">
        Rejoignez plus de 12 000 apprenants qui développent
        leurs compétences avec nos experts en ligne.
      </p>
      <ul class="feature-list">
        <li>
          <span class="feat-dot">✦</span>
          Accès à plus de 400 cours certifiants
        </li>
        <li>
          <span class="feat-dot">✦</span>
          Suivi personnalisé par un mentor dédié
        </li>
        <li>
          <span class="feat-dot">✦</span>
          Certificats reconnus par les entreprises
        </li>
        <li>
          <span class="feat-dot">✦</span>
          Communauté d'apprenants active 24/7
        </li>
      </ul>
    </div>

    <div class="reg-form-side">
      <div class="form-header">
        <h2>Créer un compte</h2>
        <p>Déjà inscrit ? <a href="#">Connectez-vous ici</a></p>
      </div>

      <div class="social-btns">
        <button class="social-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Google
        </button>
        <button class="social-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </button>
      </div>

      <div class="divider">ou avec votre email</div>

      <form onsubmit="handleRegister(event)">
        <div class="form-row">
          <div class="field">
            <label>Prénom</label>
            <input type="text" placeholder="Marie" required />
          </div>
          <div class="field">
            <label>Nom</label>
            <input type="text" placeholder="Dupont" required />
          </div>
        </div>

        <div class="field">
          <label>Adresse email</label>
          <input type="email" placeholder="marie.dupont@exemple.fr" required />
        </div>

        <div class="field">
          <label>Domaine d'apprentissage</label>
          <select>
            <option value="">Choisir un domaine…</option>
            <option>Développement Web</option>
            <option>Data Science & IA</option>
            <option>Design UX/UI</option>
            <option>Marketing Digital</option>
            <option>Gestion de Projet</option>
            <option>Cybersécurité</option>
          </select>
        </div>

        <div class="field">
          <label>Mot de passe</label>
          <div class="password-wrap">
            <input type="password" id="pw" placeholder="Minimum 8 caractères" oninput="checkStrength(this.value)" required />
            <button type="button" class="toggle-pw" onclick="togglePw()">VOIR</button>
          </div>
          <div class="strength-bar"><div class="strength-fill" id="strength-fill"></div></div>
        </div>

        <div class="checkbox-row">
