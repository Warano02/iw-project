<!-- TOAST -->
<div class="toast" id="toast">
  <div class="toast-dot"></div>
  <span id="toast-msg">Action réalisée avec succès</span>
</div>

<script>
  /* ── Tabs ── */
  function switchTab(tab) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('page-' + tab).classList.add('active');
    event.currentTarget.classList.add('active');
  }

  /* ── Password strength ── */
  function checkStrength(val) {
    const fill = document.getElementById('strength-fill');
    let score = 0;
    if (val.length >= 8) score++;
    if (/[A-Z]/.test(val)) score++;
    if (/[0-9]/.test(val)) score++;
    if (/[^A-Za-z0-9]/.test(val)) score++;
    const colors = ['#f87171','#fb923c','#facc15','#4ade80'];
    fill.style.width = (score * 25) + '%';
    fill.style.background = colors[score - 1] || 'transparent';
  }

  function togglePw() {
    const pw = document.getElementById('pw');
    pw.type = pw.type === 'password' ? 'text' : 'password';
  }

  /* ── Register ── */
  function handleRegister(e) {
    e.preventDefault();
    showToast('🎉 Compte créé avec succès ! Vérifiez votre email.');
  }

  /* ── Drag & drop ── */
  function handleDragover(e) {
    e.preventDefault();
    document.getElementById('dropzone').classList.add('dragover');
  }
  function handleDragleave() {
    document.getElementById('dropzone').classList.remove('dragover');
  }
  function handleDrop(e) {
    e.preventDefault();
    document.getElementById('dropzone').classList.remove('dragover');
    addFiles(e.dataTransfer.files);
  }
  function handleFileSelect(e) { addFiles(e.target.files); }

  let files = [];
  function addFiles(fileList) {
    [...fileList].forEach(f => {
      files.push(f);
      renderFileItem(f);
    });
  }

  function renderFileItem(f) {
    const ext = f.name.split('.').pop().toUpperCase().slice(0, 4);
    const size = f.size < 1024*1024
      ? (f.size / 1024).toFixed(1) + ' Ko'
      : (f.size / 1024 / 1024).toFixed(1) + ' Mo';
    const div = document.createElement('div');
    div.className = 'file-item';
    div.innerHTML = `
      <div class="file-icon">${ext}</div>
      <div class="file-info">
        <strong>${f.name}</strong>
        <span>${size}</span>
      </div>
      <button class="file-remove" onclick="removeFile(this, '${f.name}')">✕</button>
    `;
    document.getElementById('file-list').appendChild(div);
  }

  function removeFile(btn, name) {
    files = files.filter(f => f.name !== name);
    btn.closest('.file-item').remove();
  }

  /* ── Assignment actions ── */
  function saveDraft() { showToast('💾 Brouillon enregistré.'); }

  function submitAssignment() {
    if (files.length === 0) {
      showToast('⚠️ Veuillez ajouter au moins un fichier avant de soumettre.');
      return;
    }
    showToast('✅ Assignment soumis ! Votre instructeur a été notifié.');
  }

  /* ── Toast ── */
  let toastTimer;
  function showToast(msg) {
    clearTimeout(toastTimer);
    document.getElementById('toast-msg').textContent = msg;
    document.getElementById('toast').classList.add('show');
    toastTimer = setTimeout(() => document.getElementById('toast').classList.remove('show'), 3800);
  }
</script>
</body>
